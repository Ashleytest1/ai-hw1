rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.email is string;
    }
    function isSchoolEmail() {
      return signedIn()
        && request.auth.token.email.matches('.*@(ntnu\.edu\.tw|gapps\.ntnu\.edu\.tw)$');
    }
    function staffPath() {
      return /databases/$(database)/documents/staff/$(request.auth.token.email);
    }
    function staffData() {
      return get(staffPath()).data;
    }
    function isStaff() {
      return isSchoolEmail() && exists(staffPath());
    }
    function isAdmin() {
      return isSchoolEmail()
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    function titleMatchesStaff() {
      return request.resource.data.userTitle == staffData().title
        || ('titles' in staffData() && request.resource.data.userTitle in staffData().titles);
    }
    function submissionMatchesStaff() {
      return request.resource.data.authEmail == request.auth.token.email
        && request.resource.data.userName == staffData().name
        && request.resource.data.userDept == staffData().dept
        && titleMatchesStaff();
    }
    match /artifacts/{appId}/public/data/submissions/{subId} {
      allow create, update: if isStaff()
                            && request.auth.uid == subId
                            && submissionMatchesStaff();
      allow read, delete:   if signedIn()
                            && (request.auth.uid == subId || isAdmin());
    }
    match /staff/{email} {
      allow get:  if signedIn() && (request.auth.token.email == email || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }
    match /admins/{email} {
      allow get:  if signedIn() && (request.auth.token.email == email || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }
  }
}
